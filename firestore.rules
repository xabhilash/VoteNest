rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Public profile + per-user private subcollections (bookmarks, myQuests).
    match /Users/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid);
      allow delete: if false;

      match /bookmarks/{questId} {
        allow read, write: if isOwner(uid);
      }

      match /myQuests/{questId} {
        allow read, write: if isOwner(uid);
      }
    }

    // Public question feed.
    match /Quest/{questId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.user.userId in [request.auth.uid, 'Anon'];
      // Counters (totalAnswers, totalComments, totalUpVotes, totalDownVotes)
      // are bumped by other signed-in users when they vote / comment / answer.
      allow update: if isSignedIn();
      allow delete: if isSignedIn()
                    && resource.data.user.userId == request.auth.uid;

      // Shared answer tally for the poll.
      match /answers/{docId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      // One doc per voter on the question itself.
      match /upVotes/{uid} {
        allow read: if true;
        allow create, delete: if isOwner(uid);
        allow update: if false;
      }
      match /downVotes/{uid} {
        allow read: if true;
        allow create, delete: if isOwner(uid);
        allow update: if false;
      }

      // Comments under a question.
      match /Comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn()
                      && resource.data.user.userId == request.auth.uid;

        match /upVotes/{uid} {
          allow read: if true;
          allow create, delete: if isOwner(uid);
          allow update: if false;
        }
        match /downVotes/{uid} {
          allow read: if true;
          allow create, delete: if isOwner(uid);
          allow update: if false;
        }

        // Replies under a comment.
        match /Replies/{replyId} {
          allow read: if true;
          allow create: if isSignedIn();
          allow update: if isSignedIn();
          allow delete: if isSignedIn()
                        && resource.data.user.userId == request.auth.uid;

          match /upVotes/{uid} {
            allow read: if true;
            allow create, delete: if isOwner(uid);
            allow update: if false;
          }
          match /downVotes/{uid} {
            allow read: if true;
            allow create, delete: if isOwner(uid);
            allow update: if false;
          }
        }
      }
    }

    // Anything else: locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
